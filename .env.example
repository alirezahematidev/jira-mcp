# --- Jira credentials (required) ---------------------------------------------
# The Jira host is hardcoded to the company instance; you only need these two.
# Create an API token at:
#   https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=you@digikala.com
JIRA_API_TOKEN=your-api-token

# --- optional ----------------------------------------------------------------
# Override the hardcoded host only if it ever moves (no trailing slash).
# JIRA_URL=https://works.digikala.com
# Set to false if the host is Jira Server / Data Center rather than Cloud.
# JIRA_IS_CLOUD=true
# Request timeout in seconds (default 30).
# JIRA_TIMEOUT=30
# Verify TLS certificates (default true).
# JIRA_VERIFY_SSL=true
# Disable all create/update/delete tools (default false).
# JIRA_READ_ONLY=false
