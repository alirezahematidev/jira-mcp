# --- Jira connection ---------------------------------------------------------

# Base URL of your Jira instance (no trailing slash).
#   Cloud:      https://your-domain.atlassian.net
#   Server/DC:  https://jira.your-company.com
JIRA_URL=https://your-domain.atlassian.net

# Authentication mode: "basic" (Jira Cloud) or "bearer" (Server/DC PAT).
JIRA_AUTH_TYPE=basic

# --- basic auth (Jira Cloud) -------------------------------------------------
# Your Atlassian account email + an API token.
# Create a token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-api-token

# --- bearer auth (Jira Server / Data Center) ---------------------------------
# Personal Access Token. Only used when JIRA_AUTH_TYPE=bearer.
# JIRA_PERSONAL_TOKEN=your-personal-access-token

# --- optional ----------------------------------------------------------------
# Request timeout in seconds (default 30).
# JIRA_TIMEOUT=30
# Verify TLS certificates (default true). Set to false only for trusted dev hosts.
# JIRA_VERIFY_SSL=true
# Set to true to allow tools that modify/delete data (default true).
# JIRA_READ_ONLY=false
